# Upstream target (for local 3cket app, use http://nginx:80)
# For production, use https://3cket.com
UPSTREAM_URL=

# Host header to send to upstream (must match nginx server_name)
UPSTREAM_HOST=

# MongoDB
MONGO_URI=

# Redis
REDIS_ADDR=

# Logging
LOG_TTL_DAYS=
LOG_BODY_MAX_BYTES=

# Admin token for dashboard API
SENTINEL_ADMIN_TOKEN=

# Brain polling
POLL_INTERVAL_SEC=
AI_AUTOBLOCK=
